# ── Claude Q&A ────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Email notifications (Gmail recommended) ───────────────────────────────────
# For Gmail: enable 2FA, then create an App Password at myaccount.google.com/apppasswords
NOTIFY_EMAIL_FROM=you@gmail.com
NOTIFY_EMAIL_PASSWORD=xxxx-xxxx-xxxx-xxxx    # Gmail App Password (not your login password)
NOTIFY_EMAIL_TO=you@gmail.com,another@email.com   # comma-separated recipients

# SMTP settings (defaults work for Gmail)
NOTIFY_SMTP_HOST=smtp.gmail.com
NOTIFY_SMTP_PORT=587

# ── SMS notifications (free — uses email-to-SMS carrier gateway) ──────────────
# Just enter your 10-digit phone number and your carrier name
NOTIFY_PHONE=5551234567
NOTIFY_CARRIER=att     # att | verizon | tmobile | sprint | boost | cricket | metro | uscellular | virgin

# ── Monitor schedule (default: weekdays 5:05 PM Eastern) ─────────────────────
MONITOR_HOUR=17
MONITOR_MINUTE=5
